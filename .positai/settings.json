{
  "sandbox": {
    "enabled": false
  },
  "permission": {
    "bash": {
      "cd *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "Rscript *": "allow",
      "air *": "allow",
      "*": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git push *": "allow"
    },
    "edit": {
      "*.R": "allow",
      "*.yml": "allow",
      "*/DESCRIPTION": "allow",
      "*.yaml": "allow",
      "*.Rmd": "allow",
      "*.md": "allow"
    },
    "executeCode": {
      "*": "allow"
    }
  }
}